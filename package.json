{
  "name": "doeon-kim-portfolio",
  "private": true,
  "version": "0.0.0",
  "description": "Operations-first systems gallery for AI runtimes, operations workbenches, data contracts, and applied ML workflows",
  "homepage": "https://kim3310-doeon-kim-portfolio.pages.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/KIM3310/doeon-kim-portfolio.git"
  },
  "keywords": [
    "systems-gallery",
    "react",
    "vite",
    "typescript",
    "ai-engineer"
  ],
  "license": "MIT",
  "author": "Doeon Kim",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:chrome": "node scripts/chrome-service-audit.mjs",
    "evidence:capture": "node scripts/capture-portfolio-evidence.mjs",
    "evidence:reel": "node scripts/create-evidence-reel.mjs",
    "verify": "npm run typecheck && npm test && npm run verify:content && npm run build",
    "verify:content": "node scripts/verify-gallery.mjs",
    "fabtwin:runtime": "node server/index.mjs",
    "fabtwin:runtime:mock": "FABPILOT_ALLOW_MOCK=1 node server/index.mjs",
    "fabpilot:runtime": "node server/index.mjs",
    "fabpilot:runtime:mock": "FABPILOT_ALLOW_MOCK=1 node server/index.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
