  "version": "0.0.0",
  "description": "Neutral technical systems gallery for AI runtimes, operations workbenches, data contracts, and applied ML workflows",
  "homepage": "https://kim3310.github.io/doeon-kim-portfolio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/KIM3310/doeon-kim-portfolio.git"
  },
  "keywords": [
    "systems-gallery",
    "react",
    "vite",
    "typescript",
    "ai-engineer"
  ],
  "license": "MIT",
  "author": "Doeon Kim",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm test && npm run verify:content && npm run build",
    "verify:content": "node scripts/verify-gallery.mjs",
    "fabtwin:runtime": "node server/index.mjs",
    "fabtwin:runtime:mock": "FABPILOT_ALLOW_MOCK=1 node server/index.mjs",
    "fabpilot:runtime": "node server/index.mjs",
    "fabpilot:runtime:mock": "FABPILOT_ALLOW_MOCK=1 node server/index.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.34.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
